{
  "name": "esim-management-app",
  "version": "1.0.7",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/generate-native-push-config.mjs",
    "generate:icons": "npx -y tsx scripts/generate-icons.mjs",
    "dev": "vite",
    "check:thin-pages": "node scripts/check-thin-pages.mjs",
    "build": "vite build",
    "native:refresh": "npm run generate:icons && npm run build && rm -rf ios/App/App/public/* android/app/src/main/assets/public/* && cp -R build/. ios/App/App/public/ && cp -R build/. android/app/src/main/assets/public/ || true",
    "preview": "vite preview",
    "android:sync": "npm run native:refresh && npx cap sync android && node scripts/ensure-android-perms.mjs",
    "android:version:bump": "node scripts/bump-android-version.mjs",
    "android:release": "npm run android:sync && npm run android:version:bump && cd android && JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\" ./gradlew bundleRelease",
    "android:open": "npx cap open android",
    "android:run": "npm run android:sync && npx cap run android",
    "ios:sync": "npm run native:refresh && npx cap sync ios && node scripts/patch-ios-capapp-spm.mjs",
    "ios:open": "npx cap open ios",
    "ios:run": "npm run ios:sync && npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/core": "8.2.0",
    "@capacitor/ios": "8.2.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.0.6",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.487.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-i18next": "^17.0.4",
    "react-resizable-panels": "^2.1.7",
    "react-router": "^7.1.3",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "8.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
