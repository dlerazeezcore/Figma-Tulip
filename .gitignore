android/app/src/main/res/mipmap-xxxhdpi/ic_launcher_foreground.png

# Gradle wrapper jar — binary, gets mangled in transit. The
# `pnpm fix:gradle` script downloads a fresh copy (it runs
# automatically as a prebuild step for the android scripts).
android/gradle/wrapper/gradle-wrapper.jar

